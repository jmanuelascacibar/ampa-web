---
/*
  Noticias listing page — shows all articles sorted newest-first.
  Uses Astro's content collections API to fetch articles from
  src/content/articles/ and renders them as a responsive card grid.
*/

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base-layout.astro";
import ArticleCard from "../../components/article-card.astro";

// Fetch all articles and sort by date (newest first)
const articles = await getCollection("articles");
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Collect all unique tags across all articles
const allTags = [...new Set(articles.flatMap(a => a.data.tags))].sort();
---

<BaseLayout
  title="Noticias — AMPA Colegio Santa Catalina de Sena"
  description="Últimas noticias, novedades y actividades del AMPA del Colegio Santa Catalina de Sena."
>
  <!--
    ============================================================
    HERO — Dark burgundy gradient, matching other pages
    ============================================================
  -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 px-4 py-24 md:py-32">
    <!-- Decorative background shapes -->
    <div class="absolute -top-20 -right-20 h-96 w-96 rounded-full bg-primary-600/20 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 h-80 w-80 rounded-full bg-accent-200/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white md:text-5xl">
        Noticias del AMPA
      </h1>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent-200"></div>
      <p class="mt-8 text-lg leading-relaxed text-white/85 md:text-xl">
        Mantente al día de las novedades, eventos y actividades de nuestra
        comunidad educativa.
      </p>
    </div>
  </section>

  <!--
    ============================================================
    ARTICLE GRID — Cards on a warm gray background
    ============================================================
  -->
  <section class="bg-gray-50 px-4 py-16 md:py-24">
    <div class="mx-auto max-w-6xl">
      <!-- Section heading with decorative underline -->
      <div class="text-center">
        <h2 class="heading-underline heading-underline-center text-2xl font-bold text-primary-700 md:text-3xl">
          Últimas noticias
        </h2>
      </div>

      <!-- Tag filter bar -->
      {allTags.length > 0 && (
        <div class="mt-8 flex flex-wrap justify-center gap-2" id="tag-filters">
          <button
            data-filter="all"
            class="rounded-full border border-primary-600 bg-primary-600 px-4 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-primary-700"
          >
            Todas
          </button>
          {allTags.map(tag => (
            <button
              data-filter={tag}
              class="rounded-full border border-primary-300 bg-white px-4 py-1.5 text-sm text-primary-700 transition-colors hover:bg-primary-50"
            >
              {tag}
            </button>
          ))}
        </div>
      )}

      <!--
        Responsive grid:
        - Mobile: 1 column
        - Tablet (md): 2 columns
        - Desktop (lg): 3 columns
      -->
      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <div data-tags={article.data.tags.join(',')}>
            <ArticleCard
              title={article.data.title}
              date={article.data.date}
              excerpt={article.data.excerpt}
              author={article.data.author}
              featuredImage={article.data.featuredImage}
              tags={article.data.tags}
              slug={article.id}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('#tag-filters [data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-tags]');

  const activeClasses = ['bg-primary-600', 'text-white', 'border-primary-600', 'font-semibold'];
  const inactiveClasses = ['bg-white', 'text-primary-700', 'border-primary-300'];

  function applyFilter(selected: string) {
    // Update filter bar button styles
    buttons.forEach(b => {
      b.classList.remove(...activeClasses);
      b.classList.add(...inactiveClasses);
    });
    const activeBtn = [...buttons].find(b => b.dataset.filter === selected);
    activeBtn?.classList.remove(...inactiveClasses);
    activeBtn?.classList.add(...activeClasses);

    // Show/hide cards
    cards.forEach(card => {
      if (selected === 'all') {
        card.hidden = false;
      } else {
        const tags = card.dataset.tags?.split(',').map(t => t.trim()).filter(Boolean) ?? [];
        card.hidden = !tags.includes(selected);
      }
    });
  }

  // Filter bar buttons
  buttons.forEach(btn => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter!));
  });

  // Tag pills inside cards
  document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]').forEach(pill => {
    pill.addEventListener('click', () => applyFilter(pill.dataset.tagFilter!));
  });

  // Auto-apply filter from ?tag= URL param (e.g. coming from an article page)
  const params = new URLSearchParams(window.location.search);
  const tagParam = params.get('tag');
  if (tagParam) applyFilter(tagParam);
</script>
