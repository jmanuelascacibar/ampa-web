---
/*
  Contacto — Contact page with a form powered by Netlify Forms.
  When the site is deployed on Netlify, submitted forms are captured
  automatically (no backend code needed). During local development,
  the form submits normally but data isn't stored anywhere.

  The page also includes contact info and a short message encouraging
  families to reach out.
*/

import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout
  title="Contacto — AMPA Colegio Santa Catalina de Sena"
  description="Ponte en contacto con el AMPA del Colegio Santa Catalina de Sena. Escríbenos para resolver dudas, hacer sugerencias o participar en nuestras actividades."
>
  <!--
    ============================================================
    HERO — Dark burgundy gradient, matching other pages
    ============================================================
  -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 px-4 py-24 md:py-32">
    <div class="absolute -top-20 -right-20 h-96 w-96 rounded-full bg-primary-600/20 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 h-80 w-80 rounded-full bg-accent-200/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white md:text-5xl">
        Contacto
      </h1>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent-200"></div>
      <p class="mt-8 text-lg leading-relaxed text-white/85 md:text-xl">
        ¿Tienes alguna duda, sugerencia o quieres participar?
        Escríbenos y te responderemos lo antes posible.
      </p>
    </div>
  </section>

  <!--
    ============================================================
    CONTACT CONTENT — Form + contact info side by side
    ============================================================
  -->
  <section class="px-4 py-16 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-5">
        <!--
          CONTACT FORM — takes 3 out of 5 columns on desktop.
          The form uses Netlify Forms: adding data-netlify="true"
          tells Netlify to automatically capture submissions.
          The hidden "form-name" field is required by Netlify.
        -->
        <div class="lg:col-span-3">
          <h2 class="heading-underline text-2xl font-bold text-primary-700 md:text-3xl">
            Escríbenos
          </h2>

          <form
            name="contacto"
            method="POST"
            action="/gracias"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="mt-8 space-y-6"
          >
            <!-- Hidden field required by Netlify to identify the form -->
            <input type="hidden" name="form-name" value="contacto" />

            <!--
              Honeypot field — hidden from real users, catches spam bots.
              If a bot fills this in, Netlify silently discards the submission.
            -->
            <p class="hidden">
              <label>
                No rellenar: <input name="bot-field" />
              </label>
            </p>

            <!-- Name field -->
            <div>
              <label for="nombre" class="block text-sm font-semibold text-body">
                Nombre completo
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre y apellidos"
                class="mt-2 w-full rounded-lg border border-gray-300 px-4 py-3 text-body shadow-sm transition-colors placeholder:text-body-light focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
              />
            </div>

            <!-- Email field -->
            <div>
              <label for="email" class="block text-sm font-semibold text-body">
                Correo electrónico
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tu@email.com"
                class="mt-2 w-full rounded-lg border border-gray-300 px-4 py-3 text-body shadow-sm transition-colors placeholder:text-body-light focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
              />
            </div>

            <!-- Subject field -->
            <div>
              <label for="asunto" class="block text-sm font-semibold text-body">
                Asunto
              </label>
              <select
                id="asunto"
                name="asunto"
                required
                class="mt-2 w-full rounded-lg border border-gray-300 px-4 py-3 text-body shadow-sm transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
              >
                <option value="" disabled selected>Selecciona un asunto</option>
                <option value="informacion">Información general</option>
                <option value="inscripcion">Inscripción al AMPA</option>
                <option value="actividades">Actividades y eventos</option>
                <option value="sugerencia">Sugerencia o propuesta</option>
                <option value="voluntariado">Quiero ser voluntario/a</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <!-- Message textarea -->
            <div>
              <label for="mensaje" class="block text-sm font-semibold text-body">
                Mensaje
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                required
                placeholder="Escribe tu mensaje aquí..."
                class="mt-2 w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-body shadow-sm transition-colors placeholder:text-body-light focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
              ></textarea>
            </div>

            <!-- Submit button — pill-shaped, burgundy with lime-green hover -->
            <div>
              <button
                type="submit"
                class="inline-block w-full rounded-full bg-primary-600 px-8 py-3 text-base font-semibold text-white shadow-md transition-all duration-300 hover:bg-accent-200 hover:text-primary-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
              >
                Enviar mensaje
              </button>
            </div>
          </form>
        </div>

        <!--
          CONTACT INFO — takes 2 out of 5 columns on desktop.
          Shows address, email, and a short encouraging message.
        -->
        <div class="lg:col-span-2">
          <h2 class="heading-underline text-2xl font-bold text-primary-700 md:text-3xl">
            Información
          </h2>

          <div class="mt-8 space-y-6">
            <!-- Address -->
            <div class="flex items-start gap-3">
              <div class="flex h-10 w-10 min-w-10 items-center justify-center rounded-full bg-primary-50">
                <svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-body">Dirección</p>
                <p class="mt-1 text-sm leading-relaxed text-body-light">
                  Av. de Alfonso XIII, 160, Chamartín, 28016<br />
                  Madrid
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-3">
              <div class="flex h-10 w-10 min-w-10 items-center justify-center rounded-full bg-primary-50">
                <svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-body">Correo electrónico</p>
                <a href="mailto:ampa@colegiosantacatalina.es" class="mt-1 block text-sm text-primary-600 transition-colors hover:text-primary-800">
                  ampasantacatalinadesena@dominicasmadrid.es
                </a>
              </div>
            </div>

            <!-- Encouraging message card -->
            <div class="mt-8 rounded-2xl bg-primary-50 p-6">
              <p class="font-semibold text-primary-700">
                ¡Tu participación importa!
              </p>
              <p class="mt-2 text-sm leading-relaxed text-primary-800/80">
                El AMPA somos todas las familias. Si quieres colaborar como
                voluntario/a, proponer una actividad o simplemente estar más
                informado/a, no dudes en escribirnos. Cada aportación hace
                más fuerte nuestra comunidad.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
