---
/*
  ProjectCard: A card for displaying an AMPA project/initiative.
  Shows an icon, title, description, impact, and future plans.
  Each card has a numbered badge and a colored left border accent.

  Props:
  - number: the project number (shown in the badge)
  - title: the project's name
  - description: what the project does
  - impact: (optional) the measurable effect on the community
  - futurePlans: array of upcoming initiatives within this project
  - icon: (optional) emoji or short string shown in the badge area
*/

interface Props {
  number: number;
  title: string;
  description: string;
  impact?: string;
  futurePlans: string[];
  icon?: string;
}

const { number, title, description, impact, futurePlans, icon } = Astro.props;
---

<!--
  Card container — white background with a burgundy left border accent.
  The border-l-4 creates a colored stripe on the left edge that visually
  connects the card to the AMPA brand and adds hierarchy.
-->
<article class="overflow-hidden rounded-2xl border-l-4 border-primary-600 bg-white p-6 shadow-md md:p-8">
  <!-- Header row: numbered badge + title -->
  <div class="flex items-start gap-4">
    <!--
      Numbered badge — a small burgundy circle with the project number.
      If an icon emoji is provided, it's shown below the number.
    -->
    <div class="flex h-12 w-12 min-w-12 flex-col items-center justify-center rounded-full bg-primary-600 text-sm font-bold text-white">
      {icon ? (
        <span class="text-lg">{icon}</span>
      ) : (
        <span>{number}</span>
      )}
    </div>

    <div class="flex-1">
      <!-- Project title -->
      <h3 class="text-xl font-bold text-body">
        {title}
      </h3>
    </div>
  </div>

  <!-- Description -->
  <p class="mt-4 text-base leading-relaxed text-body-light">
    {description}
  </p>

  <!-- Impact section — only shown if provided -->
  {impact && (
    <div class="mt-4 rounded-lg bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-700">
        Impacto
      </p>
      <p class="mt-1 text-sm leading-relaxed text-primary-800/80">
        {impact}
      </p>
    </div>
  )}

  <!-- Future plans — shown as a list with accent-colored bullets -->
  {futurePlans.length > 0 && (
    <div class="mt-5">
      <p class="text-sm font-semibold text-accent-600">
        Planes futuros
      </p>
      <ul class="mt-2 space-y-2">
        {futurePlans.map((plan) => (
          <li class="flex items-start gap-2 text-sm leading-relaxed text-body-light">
            <span class="mt-1.5 block h-1.5 w-1.5 min-w-1.5 rounded-full bg-accent-400" aria-hidden="true"></span>
            {plan}
          </li>
        ))}
      </ul>
    </div>
  )}
</article>
