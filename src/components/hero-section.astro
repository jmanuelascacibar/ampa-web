---
/*
  HeroSection: The big welcome banner at the top of the homepage.
  It shows a heading, a subtitle, and a call-to-action button.

  Props:
  - heading: the large title text
  - subtitle: a short paragraph below the heading
  - ctaText: the text on the button (optional)
  - ctaHref: where the button links to (optional)
*/

interface Props {
  heading: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  heading,
  subtitle,
  ctaText = "Conócenos",
  ctaHref = "/quienes-somos",
} = Astro.props;
---

<!-- Full-width hero section with a soft gradient background -->
<section class="relative bg-gradient-to-br from-primary-50 via-white to-accent-50 py-20 px-4 md:py-32">
  <div class="mx-auto max-w-3xl text-center">
    <!-- Main heading — only h1 on the page -->
    <h1 class="text-4xl font-extrabold tracking-tight text-primary-800 md:text-5xl lg:text-6xl">
      {heading}
    </h1>

    <!-- Subtitle paragraph with generous spacing -->
    <p class="mt-6 text-lg leading-relaxed text-gray-600 md:text-xl">
      {subtitle}
    </p>

    <!-- Call-to-action button -->
    <div class="mt-10">
      <a
        href={ctaHref}
        class="inline-block rounded-full bg-primary-600 px-8 py-3 text-lg font-semibold text-white shadow-md transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
