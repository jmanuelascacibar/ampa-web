---
/*
  ArticleCard: A reusable card for displaying an article preview.
  Shows a featured image, date, title, author, excerpt, and a "Leer más" link.
  Used on the listing page (/noticias) and the homepage preview section.

  Props:
  - title: the article's headline
  - date: publication date (Date object)
  - excerpt: short summary shown on the card
  - author: who wrote the article
  - featuredImage: URL to the hero image
  - slug: the URL-friendly identifier (used to build the link)
*/

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  author: string;
  featuredImage: string;
  slug: string;
}

const { title, date, excerpt, author, featuredImage, slug } = Astro.props;

// Format the date in Spanish: "15 de noviembre de 2025"
const formattedDate = date.toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<!--
  Card container — white background with rounded corners and shadow.
  overflow-hidden clips the image to the card's rounded shape.
  The "group" class lets child elements react to card hover.
-->
<article class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-md transition-shadow duration-300 hover:shadow-lg">
  <!-- Featured image — full width at the top of the card -->
  <a href={`/noticias/${slug}`} class="block overflow-hidden">
    <img
      src={featuredImage}
      alt={title}
      class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
  </a>

  <!-- Card content area -->
  <div class="flex flex-1 flex-col p-6">
    <!-- Date -->
    <time datetime={date.toISOString()} class="text-sm text-body-light">
      {formattedDate}
    </time>

    <!-- Title — links to the full article -->
    <h3 class="mt-2 text-lg font-bold text-body transition-colors group-hover:text-primary-600">
      <a href={`/noticias/${slug}`}>
        {title}
      </a>
    </h3>

    <!-- Author name -->
    <p class="mt-1 text-sm font-semibold text-accent-600">
      {author}
    </p>

    <!-- Excerpt — secondary text, grows to push the button down -->
    <p class="mt-3 flex-1 text-sm leading-relaxed text-body-light">
      {excerpt}
    </p>

    <!-- "Leer más" link — pill-shaped, burgundy with lime-green hover -->
    <div class="mt-5">
      <a
        href={`/noticias/${slug}`}
        class="inline-block rounded-full bg-primary-600 px-6 py-2 text-sm font-semibold text-white transition-all duration-300 hover:bg-accent-200 hover:text-primary-900"
      >
        Leer más
      </a>
    </div>
  </div>
</article>
